{
  "name": "csv-to-table-filler",
  "version": "1.0.0",
  "description": "Browser extension (multi-target foundation) that automates filling HTML tables using CSV files with custom column mapping",
  "license": "MIT",
  "author": "sbonoc",
  "scripts": {
    "prepare:browser": "node scripts/prepare-browser-target.js",
    "prepare:browser:firefox": "node scripts/prepare-browser-target.js firefox",
    "prepare:browser:chrome": "node scripts/prepare-browser-target.js chrome",
    "prepare:browser:edge": "node scripts/prepare-browser-target.js edge",
    "start": "npm run prepare:browser:firefox && web-ext run",
    "start:firefox": "npm run prepare:browser:firefox && web-ext run",
    "build": "npm run prepare:browser:firefox && web-ext build --overwrite-dist",
    "build:firefox": "npm run prepare:browser:firefox && web-ext build --overwrite-dist",
    "lint": "npm run prepare:browser:firefox && web-ext lint --ignore-files tests/** --ignore-files scripts/** --ignore-files test-results/** --ignore-files playwright-results/**",
    "test": "vitest",
    "test:unit": "vitest run --reporter=json --outputFile=test-results/unit.json tests/unit",
    "test:integration": "vitest run --reporter=json --outputFile=test-results/integration.json tests/integration",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.js",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e && node scripts/generate-test-report.js",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:server": "node scripts/test-server.js",
    "ci:test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "audit:prod": "npm audit --omit=dev"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.40.0",
    "@testing-library/dom": "^9.3.3",
    "@testing-library/user-event": "^14.5.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^20.7.0",
    "playwright": "^1.40.0",
    "vitest": "^4.0.18",
    "web-ext": "^9.3.0",
    "webextension-polyfill": "^0.10.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sbonoc/firefox-addon-csv-to-table-filler.git"
  },
  "keywords": [
    "browser-extension",
    "webextension",
    "multi-browser",
    "firefox",
    "csv",
    "table",
    "form-filler",
    "automation"
  ],
  "overrides": {
    "ajv": "8.18.0"
  }
}
