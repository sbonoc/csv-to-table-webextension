{
  "name": "csv-to-table-filler",
  "version": "1.0.0",
  "description": "Firefox extension that automates filling HTML tables using CSV files with custom column mapping",
  "license": "MIT",
  "author": "sbonoc",
  "scripts": {
    "start": "web-ext run",
    "build": "web-ext build --overwrite-dist",
    "lint": "web-ext lint",
    "test": "vitest",
    "test:unit": "vitest run --reporter=json --outputFile=test-results/unit.json src/**/*.test.js popup/**/*.test.js 2>&1 | tail -1",
    "test:integration": "vitest run --reporter=json --outputFile=test-results/integration.json tests/integration 2>&1 | tail -1",
    "test:e2e": "playwright test 2>&1 | tail -1",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e && node scripts/generate-test-report.js",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:server": "node scripts/test-server.js",
    "ci:test": "npm run test:unit && npm run test:integration && npm run test:e2e"
  },
  "devDependencies": {
    "web-ext": "^7.10.0",
    "vitest": "^0.34.0",
    "@testing-library/dom": "^9.3.3",
    "@testing-library/user-event": "^14.5.1",
    "@vitest/ui": "^0.34.0",
    "@vitest/coverage-v8": "^0.34.0",
    "happy-dom": "^12.10.3",
    "webextension-polyfill": "^0.10.0",
    "playwright": "^1.40.0",
    "@playwright/test": "^1.40.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sbonoc/firefox-addon-csv-to-table-filler.git"
  },
  "keywords": [
    "firefox",
    "csv",
    "table",
    "form-filler",
    "automation"
  ]
}
